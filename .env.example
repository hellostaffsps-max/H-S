# App URL for OAuth redirects & deployment
APP_URL="https://www.staffps.com"
NEXT_PUBLIC_APP_URL="https://www.staffps.com"

# Supabase Configuration
# You must provide these values in the AI Studio Settings (Secrets)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Service Role Key (required for admin scripts - NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=""

# Gemini API Key (optional depending on usage)
GEMINI_API_KEY=""

# Upstash Redis (optional - for production rate limiting)
# Get from https://upstash.com/
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
